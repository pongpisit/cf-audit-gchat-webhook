CF_ACCOUNT_ID=YOUR_ACCOUNT_ID
CF_API_TOKEN=YOUR_API_TOKEN_WITH_AUDIT_LOG_READ
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE/messages?key=KEY&token=TOKEN

# Optional routing webhooks
GCHAT_WEBHOOK_SECURITY=
GCHAT_WEBHOOK_CONFIG=

# Optional filtering controls
# ALERT_MODE=all|important
ALERT_MODE=important
# ALERT_ACTION_ALLOWLIST=token,member,dns,waf,ssl,workers
ALERT_ACTION_ALLOWLIST=
